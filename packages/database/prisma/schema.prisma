// Prisma schema for Content Platform
// https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ----- Auth (NextAuth compatible) -----
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  role          Role      @default(USER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]
  techVaultReviews TechVaultReview[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token     String   @unique
  expires   DateTime

  @@unique([identifier, token])
}

enum Role {
  USER
  EDITOR
  ADMIN
}

// ----- TechVault: Product reviews & showcases -----
model TechVaultReview {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  summary     String?  @db.Text
  body        String   @db.Text
  rating      Int      // 1-5
  productName String
  category    TechVaultCategory
  imageUrl    String?
  published   Boolean  @default(false)
  publishedAt DateTime?
  authorId    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([category])
  @@index([published, publishedAt])
  @@index([authorId])
}

enum TechVaultCategory {
  TECHNOLOGY
  MENS_LIFESTYLE
  AUTOMOTIVE
  INNOVATION
}
