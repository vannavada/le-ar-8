// Prisma schema for Content Platform
// https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ----- Auth (NextAuth compatible) -----
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  role          Role      @default(USER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]
  articles Article[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token     String   @unique
  expires   DateTime

  @@unique([identifier, token])
}

enum Role {
  USER
  EDITOR
  ADMIN
}

// ----- Content hubs (shared Article model) -----

enum Hub {
  TECH_VAULT
  THOUGHT_FORGE
  FINANCE_HUB
  LEARN_HUB
}

model Article {
  id          String    @id @default(cuid())
  hub         Hub
  title       String
  slug        String
  summary     String?   @db.Text
  body        String    @db.Text
  tags        String[]  @default([])
  published   Boolean   @default(false)
  publishedAt DateTime?
  authorId    String
  author      User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Optional review fields — TechVault review-type pieces only; null otherwise
  rating          Int?
  productName     String?
  productCategory String?

  @@unique([hub, slug])
  @@index([hub, published, publishedAt])
  @@index([authorId])
}

// ----- /now page (singleton) -----

model NowPage {
  id        String   @id @default(cuid())
  body      String   @db.Text
  updatedAt DateTime @updatedAt
}

// ----- Affiliate programs -----

model AffiliateProgram {
  id          String   @id @default(cuid())
  name        String   // e.g. "Amazon Associates"
  network     String   // e.g. "amazon"
  affiliateId String   // e.g. "lear8-20" — the tracking tag/ID for this program
  baseUrl     String   // e.g. "https://www.amazon.com"
  commission  String?  // e.g. "3–10%"
  categories  String[] @default([])
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
