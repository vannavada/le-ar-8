# Application
NODE_ENV=development
PORT=3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000

# Database
DATABASE_URL=postgresql://admin:devpassword@localhost:5432/content_platform
DB_PASSWORD=devpassword

# Redis
REDIS_URL=redis://:devpassword@localhost:6379
REDIS_PASSWORD=devpassword

# Authentication
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-nextauth-secret-min-32-chars-change-in-production
NEXTAUTH_URL=http://localhost:3000
JWT_SECRET=your-jwt-secret-min-32-chars-change-in-production

# OAuth Providers (Optional)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# Stripe Payment Processing
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Plaid (Financial Institutions Integration)
PLAID_CLIENT_ID=your_plaid_client_id
PLAID_SECRET=your_plaid_secret
PLAID_ENV=sandbox # sandbox, development, production
NEXT_PUBLIC_PLAID_PUBLIC_KEY=your_plaid_public_key

# Stock Market API (Optional - choose one)
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key
FINNHUB_API_KEY=your_finnhub_key
IEX_CLOUD_API_KEY=your_iex_cloud_key

# Cryptocurrency API (Optional)
COINMARKETCAP_API_KEY=your_coinmarketcap_key
COINGECKO_API_KEY=your_coingecko_key

# Email Service (Choose one)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=your-sendgrid-api-key
EMAIL_FROM=noreply@yourplatform.com

# Alternative: Postmark
# POSTMARK_SERVER_TOKEN=your-postmark-token
# POSTMARK_FROM_EMAIL=noreply@yourplatform.com

# S3/MinIO (File Storage)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=content-platform
S3_REGION=us-east-1
NEXT_PUBLIC_S3_BUCKET_URL=http://localhost:9000/content-platform

# Alternative: AWS S3
# AWS_ACCESS_KEY_ID=your_aws_access_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret_key
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=your-bucket-name

# Cloudinary (Alternative Image Storage)
# CLOUDINARY_CLOUD_NAME=your_cloud_name
# CLOUDINARY_API_KEY=your_api_key
# CLOUDINARY_API_SECRET=your_api_secret

# Analytics
GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Error Tracking
SENTRY_DSN=https://your_sentry_dsn@sentry.io/project_id
NEXT_PUBLIC_SENTRY_DSN=https://your_sentry_dsn@sentry.io/project_id

# OpenAI (Optional - for AI features)
OPENAI_API_KEY=sk-your-openai-api-key

# Elasticsearch (Optional - for advanced search)
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_USERNAME=elastic
ELASTICSEARCH_PASSWORD=changeme

# RabbitMQ (Message Queue)
RABBITMQ_URL=amqp://admin:devpassword@localhost:5672
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=devpassword

# WebSocket
WS_PORT=8080
NEXT_PUBLIC_WS_URL=ws://localhost:8080

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000 # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100

# Feature Flags
ENABLE_SUBSCRIPTIONS=true
ENABLE_API_ACCESS=true
ENABLE_REAL_TIME=true
ENABLE_PLAID_INTEGRATION=true
ENABLE_STOCK_TRACKING=true
ENABLE_CRYPTO_TRACKING=true
ENABLE_OAUTH=false

# Security
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
CORS_CREDENTIALS=true
ENCRYPTION_KEY=your-32-char-encryption-key-for-vault

# Monitoring
PROMETHEUS_PORT=9090
GRAFANA_PORT=3003
GRAFANA_PASSWORD=admin

# Development
DEBUG=false
LOG_LEVEL=info # error, warn, info, debug

# Mobile App (Expo)
EXPO_PUBLIC_API_URL=http://localhost:4000
EXPO_PUBLIC_APP_URL=http://localhost:3000

# Admin Panel
ADMIN_EMAIL=admin@yourplatform.com
ADMIN_PASSWORD=change-this-in-production

# Deployment
VERCEL_URL=
RAILWAY_URL=
RENDER_URL=

# Backup
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * * # Daily at 2 AM
BACKUP_RETENTION_DAYS=30

# Performance
MAX_UPLOAD_SIZE=10485760 # 10MB in bytes
SESSION_TIMEOUT=86400 # 24 hours in seconds
CACHE_TTL=300 # 5 minutes in seconds

# Database Connection Pool
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10
DATABASE_TIMEOUT=20000

# Redis Configuration
REDIS_MAX_RETRIES=3
REDIS_RETRY_DELAY=1000

# API Configuration
API_TIMEOUT=30000
API_RETRY_ATTEMPTS=3

# Content
MAX_POST_LENGTH=50000
MAX_COMMENT_LENGTH=5000
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/webp,image/gif,application/pdf

# Notifications
ENABLE_EMAIL_NOTIFICATIONS=true
ENABLE_PUSH_NOTIFICATIONS=false
ENABLE_SMS_NOTIFICATIONS=false

# Price Tracking
PRICE_CHECK_INTERVAL=3600000 # 1 hour in milliseconds
PRICE_ALERT_THRESHOLD=0.05 # 5% price change

# Tax Calculation (US)
DEFAULT_TAX_STATE=CA
ENABLE_STATE_TAX=true
ENABLE_FEDERAL_TAX=true
